{
  "manifest_version": 3,
  "name": "Term Decoder",
  "version": "1.1.0",
  "description": "Decode selected terms and passages from the current page.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Term Decoder",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
